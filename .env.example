# Copy this file to .env and fill in the values for your Cloudflare R2 bucket.
# Never commit the real .env file.

# Cloudflare R2 S3 endpoint:
# https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=

# Cloudflare R2 access key pair.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Default bucket/prefixes used by adult-flag r2-upload and r2-download.
ADULT_FLAG_R2_BUCKET=
ADULT_FLAG_R2_MEDIA_PREFIX=twitter-media
ADULT_FLAG_R2_RESULTS_PREFIX=twitter-results

# Optional Ollama settings for the LLaVA second pass.
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llava:13b
